# Supabase Configuration
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase Service Role Key (server-only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NUXT_PUBLIC_APP_NAME=LMS Mahasiswa
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Demo Mode (set to 'true' to run without Supabase)
NUXT_PUBLIC_DEMO_MODE=false
